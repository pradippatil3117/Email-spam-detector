# ==============================================================================
# Aegis Email Security Console - Environment Configuration Example
# ==============================================================================
# Copy this file to '.env' and modify the values for your environment.
# Never commit real secrets or API keys to version control.
# ==============================================================================

# ------------------------------------------------------------------------------
# 1. Gateway & Frontend Configurations
# ------------------------------------------------------------------------------
# NODE_ENV: 'development' or 'production' configuration.
NODE_ENV=development

# PORT: The port that the Express bridge/reverse proxy runs on.
PORT=3000

# APP_URL: Self-referential URL where this applet is hosted.
APP_URL=http://localhost:3000

# ------------------------------------------------------------------------------
# 2. API & Service Routing Configurations
# ------------------------------------------------------------------------------
# BACKEND_URL: The HTTP URL of the FastAPI backend service.
# For local dev, this is http://localhost:8000.
# For Docker Compose setups, this is http://backend:8000.
BACKEND_URL=http://localhost:8000

# SPAWN_BACKEND: Toggle whether Express spawns the FastAPI backend uvicorn
# process as a child process. Set to false if running FastAPI in a separate
# container (like Docker) or running it manually in terminal.
SPAWN_BACKEND=true

# ------------------------------------------------------------------------------
# 3. Machine Learning & LLM Configurations
# ------------------------------------------------------------------------------
# GEMINI_API_KEY: Optional Gemini API Key for AI Studio/inference settings.
# Leave blank if using local classification model metrics only.
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE
